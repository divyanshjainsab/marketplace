<% if flash[:notice].present? %>
  <div class="mb-5 rounded-xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-emerald-900">
    <div class="text-sm font-medium"><%= flash[:notice] %></div>
  </div>
<% end %>

<% if flash[:alert].present? %>
  <div class="mb-5 rounded-xl border border-rose-200 bg-rose-50 px-4 py-3 text-rose-900">
    <div class="text-sm font-medium"><%= flash[:alert] %></div>
  </div>
<% end %>
