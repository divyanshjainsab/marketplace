<script>
  (() => {
    const classify = (el, ok) => {
      if (!el) return;
      el.classList.toggle("text-emerald-700", ok);
      el.classList.toggle("text-slate-600", !ok);
    };

    const scorePassword = (value) => {
      const v = String(value || "");
      const checks = {
        length: v.length >= 8,
        upper: /[A-Z]/.test(v),
        lower: /[a-z]/.test(v),
        number: /\d/.test(v),
        special: /[^A-Za-z0-9]/.test(v)
      };
      const passed = Object.keys(checks).filter((k) => checks[k]).length;
      return { checks, passed, total: 5 };
    };

    const strengthLabel = (passed) => {
      if (passed <= 2) return { label: "Weak", color: "bg-rose-500" };
      if (passed <= 4) return { label: "Medium", color: "bg-amber-500" };
      return { label: "Strong", color: "bg-emerald-500" };
    };

    const togglePassword = (toggle) => {
      const wrapper = toggle.closest("[data-password-wrapper]");
      if (!wrapper) return;

      const input = wrapper.querySelector("[data-password-input]");
      if (!input) return;

      const next = input.getAttribute("type") === "password" ? "text" : "password";
      input.setAttribute("type", next);

      const showIcon = toggle.querySelector("[data-password-icon='show']");
      const hideIcon = toggle.querySelector("[data-password-icon='hide']");
      const isVisible = next === "text";

      if (showIcon) showIcon.classList.toggle("hidden", isVisible);
      if (hideIcon) hideIcon.classList.toggle("hidden", !isVisible);

      toggle.setAttribute("aria-pressed", isVisible ? "true" : "false");
      toggle.setAttribute("aria-label", isVisible ? "Hide password" : "Show password");
    };

    const bindStrengthMeters = () => {
      document.querySelectorAll("[data-password-strength]").forEach((root) => {
        if (root.dataset.passwordStrengthBound === "1") return;
        root.dataset.passwordStrengthBound = "1";

        const input = root.querySelector("[data-password-input]");
        const bar = root.querySelector("[data-password-meter-bar]");
        const label = root.querySelector("[data-password-meter-label]");
        const rules = {
          length: root.querySelector("[data-password-rule='length']"),
          upper: root.querySelector("[data-password-rule='upper']"),
          lower: root.querySelector("[data-password-rule='lower']"),
          number: root.querySelector("[data-password-rule='number']"),
          special: root.querySelector("[data-password-rule='special']")
        };

        if (!input || !bar || !label) return;

        const render = () => {
          const result = scorePassword(input.value);
          const pct = Math.round((result.passed / result.total) * 100);
          const s = strengthLabel(result.passed);

          bar.style.width = `${pct}%`;
          bar.className = `h-2 rounded-full transition-all ${s.color}`;
          label.textContent = s.label;

          classify(rules.length, result.checks.length);
          classify(rules.upper, result.checks.upper);
          classify(rules.lower, result.checks.lower);
          classify(rules.number, result.checks.number);
          classify(rules.special, result.checks.special);
        };

        input.addEventListener("input", render);
        render();
      });
    };

    const bind = () => {
      if (document.documentElement.dataset.passwordEnhancementsBound !== "1") {
        document.documentElement.dataset.passwordEnhancementsBound = "1";

        document.addEventListener("click", (event) => {
          const target = event.target;
          if (!(target instanceof Element)) return;

          const toggle = target.closest("[data-password-toggle]");
          if (!toggle) return;

          event.preventDefault();
          togglePassword(toggle);
        });
      }

      bindStrengthMeters();
    };

    document.addEventListener("DOMContentLoaded", bind);
    document.addEventListener("turbo:load", bind);
    bind();
  })();
</script>
