<div class="mt-6 space-y-2 text-sm text-slate-600">
  <%- if controller_name != "sessions" %>
    <div><%= link_to "Back to sign in", login_path, class: "font-semibold text-slate-900 hover:text-slate-700" %></div>
  <% end %>

  <%- if devise_mapping.registerable? && controller_name != "registrations" %>
    <div><%= link_to "Create an account", new_registration_path(resource_name), class: "font-semibold text-slate-900 hover:text-slate-700" %></div>
  <% end %>

  <%- if devise_mapping.recoverable? && controller_name != "passwords" && controller_name != "registrations" %>
    <div><%= link_to "Reset password", new_password_path(resource_name), class: "font-semibold text-slate-900 hover:text-slate-700" %></div>
  <% end %>

  <%- if devise_mapping.confirmable? && controller_name != "confirmations" %>
    <div><%= link_to "Resend confirmation email", new_confirmation_path(resource_name), class: "font-semibold text-slate-900 hover:text-slate-700" %></div>
  <% end %>

  <%- if devise_mapping.lockable? && resource_class.unlock_strategy_enabled?(:email) && controller_name != "unlocks" %>
    <div><%= link_to "Resend unlock email", new_unlock_path(resource_name), class: "font-semibold text-slate-900 hover:text-slate-700" %></div>
  <% end %>
</div>
