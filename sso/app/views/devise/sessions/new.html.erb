<div class="mx-auto w-full max-w-md">
  <div class="rounded-2xl bg-white p-6 shadow-sm ring-1 ring-slate-200 sm:p-8">
    <div class="flex items-start justify-between gap-4">
      <div>
        <h1 class="text-xl font-semibold text-slate-900">Sign in</h1>
        <p class="mt-1 text-sm text-slate-600">Use your email and password. If two-factor is enabled, we will ask for the code next.</p>
      </div>
      <span class="inline-flex items-center rounded-full bg-slate-900 px-2.5 py-1 text-xs font-semibold text-white">SSO</span>
    </div>

    <% if resource.errors.any? %>
      <div class="mt-5 rounded-xl border border-rose-200 bg-rose-50 px-4 py-3 text-rose-900">
        <div class="text-sm font-medium"><%= resource.errors.full_messages.to_sentence %></div>
      </div>
    <% end %>

    <%= form_for(resource, as: resource_name, url: login_path, html: { class: "mt-6 space-y-4", id: "login-form" }) do |f| %>
      <%= hidden_field_tag :redirect_url, params[:redirect_uri].presence || params[:redirect_url].presence %>
      <%= hidden_field_tag :state, params[:state].presence %>
      <%= hidden_field_tag :return_to, params[:return_to].presence %>

      <div>
        <%= f.label :email, class: "block text-sm font-medium text-slate-700" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "mt-1 block w-full rounded-xl border border-slate-300 bg-white px-3 py-2 text-slate-900 shadow-sm outline-none ring-offset-2 focus:border-slate-900 focus:ring-2 focus:ring-slate-900/20", placeholder: "you@company.com" %>
      </div>

      <div>
        <div class="flex items-center justify-between">
          <%= f.label :password, class: "block text-sm font-medium text-slate-700" %>
          <%= link_to "Forgot password?", new_password_path(resource_name), class: "text-sm font-medium text-slate-700 hover:text-slate-900" %>
        </div>
        <%= render "shared/password_input",
              f: f,
              field: :password,
              autocomplete: "current-password",
              placeholder: "Enter your password",
              wrapper_class: "mt-1",
              input_class: "block w-full rounded-xl border border-slate-300 bg-white px-3 py-2 pr-12 text-slate-900 shadow-sm outline-none ring-offset-2 focus:border-slate-900 focus:ring-2 focus:ring-slate-900/20" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <label class="flex items-center gap-2 text-sm text-slate-600">
          <%= f.check_box :remember_me, class: "h-4 w-4 rounded border-slate-300 text-slate-900 focus:ring-slate-900/20" %>
          <span>Remember this device</span>
        </label>
      <% end %>

      <%= f.submit "Continue", class: "mt-2 inline-flex w-full items-center justify-center rounded-xl bg-slate-900 px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-slate-800 disabled:cursor-not-allowed disabled:opacity-70", data: { disable_with: "Checking..." } %>
    <% end %>

    <div class="mt-6 flex items-center justify-between gap-3 text-sm text-slate-600">
      <span>New here?</span>
      <%= link_to "Create an account", new_registration_path(resource_name, redirect_url: params[:redirect_uri].presence || params[:redirect_url], state: params[:state], return_to: params[:return_to]), class: "font-semibold text-slate-900 hover:text-slate-700" %>
    </div>
  </div>
</div>

<%= render "shared/password_enhancements" %>
