<div class="mx-auto w-full max-w-3xl space-y-6">
  <header class="rounded-2xl bg-white p-6 shadow-sm ring-1 ring-slate-200 sm:p-8">
    <div class="flex flex-col gap-6 sm:flex-row sm:items-start sm:justify-between">
      <div class="min-w-0">
        <p class="text-xs font-semibold uppercase tracking-[0.25em] text-slate-500">Profile</p>
        <h1 class="mt-3 text-2xl font-semibold tracking-tight text-slate-950">Your account</h1>
        <p class="mt-2 text-sm text-slate-600">Keep your profile up to date. Security settings live here too.</p>
      </div>

      <div class="flex items-center gap-3">
        <span class="inline-flex items-center rounded-full bg-slate-100 px-2.5 py-1 text-xs font-semibold text-slate-700">
          <%= current_user.email_verified? ? "Email verified" : "Email unverified" %>
        </span>
      </div>
    </div>

    <%= form_for(@user, url: profile_path, method: :patch, html: { class: "mt-8 grid gap-4 sm:grid-cols-2" }) do |f| %>
      <div class="sm:col-span-2">
        <%= f.label :name, class: "block text-sm font-medium text-slate-700" %>
        <%= f.text_field :name, autocomplete: "name", class: "mt-1 block w-full rounded-xl border border-slate-300 bg-white px-3 py-2 text-slate-900 shadow-sm outline-none ring-offset-2 focus:border-slate-900 focus:ring-2 focus:ring-slate-900/20", placeholder: "Your full name" %>
      </div>

      <div>
        <%= f.label :phone_number, class: "block text-sm font-medium text-slate-700" %>
        <%= f.telephone_field :phone_number, autocomplete: "tel", class: "mt-1 block w-full rounded-xl border border-slate-300 bg-white px-3 py-2 text-slate-900 shadow-sm outline-none ring-offset-2 focus:border-slate-900 focus:ring-2 focus:ring-slate-900/20", placeholder: "+1 555 123 4567" %>
      </div>

      <div>
        <%= f.label :avatar_url, class: "block text-sm font-medium text-slate-700" %>
        <%= f.url_field :avatar_url, autocomplete: "url", class: "mt-1 block w-full break-all rounded-xl border border-slate-300 bg-white px-3 py-2 text-slate-900 shadow-sm outline-none ring-offset-2 focus:border-slate-900 focus:ring-2 focus:ring-slate-900/20", placeholder: "https://…" %>
        <p class="mt-1 text-xs text-slate-500">Optional. Used by other apps for a consistent profile picture.</p>
      </div>

      <div class="sm:col-span-2 flex flex-col-reverse gap-3 pt-2 sm:flex-row sm:items-center sm:justify-between">
        <div class="text-sm text-slate-600">
          Signed in as <span class="break-all font-semibold text-slate-900"><%= current_user.email %></span>
        </div>
        <%= f.submit "Save profile", class: "inline-flex items-center justify-center rounded-xl bg-slate-900 px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-slate-800" %>
      </div>
    <% end %>
  </header>

  <section class="rounded-2xl bg-white p-6 shadow-sm ring-1 ring-slate-200 sm:p-8">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
      <div class="min-w-0">
        <h2 class="text-lg font-semibold text-slate-950">Addresses</h2>
        <p class="mt-1 text-sm text-slate-600">Saved addresses can be reused across apps.</p>
      </div>
      <div class="flex items-center gap-2">
        <%= link_to "Manage", addresses_path, class: "inline-flex items-center justify-center rounded-xl border border-slate-200 bg-white px-4 py-2.5 text-sm font-semibold text-slate-900 shadow-sm hover:bg-slate-50" %>
        <%= link_to "Add address", new_address_path, class: "inline-flex items-center justify-center rounded-xl bg-slate-900 px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-slate-800" %>
      </div>
    </div>

    <% if @addresses.empty? %>
      <div class="mt-6 rounded-xl border border-dashed border-slate-200 bg-slate-50 px-4 py-6 text-sm text-slate-600">
        No addresses yet. Add one to speed up checkout and admin workflows.
      </div>
    <% else %>
      <div class="mt-6 grid gap-3 sm:grid-cols-2">
        <% @addresses.each do |address| %>
          <article class="rounded-2xl border border-slate-200 bg-white p-4">
            <div class="flex items-start justify-between gap-3">
              <div class="min-w-0">
                <p class="text-xs font-semibold uppercase tracking-[0.25em] text-slate-500"><%= address.address_type %></p>
                <p class="mt-2 text-sm font-semibold text-slate-900"><%= address.line1 %></p>
                <% if address.line2.present? %>
                  <p class="text-sm text-slate-700"><%= address.line2 %></p>
                <% end %>
                <p class="mt-2 text-sm text-slate-600"><%= address.city %>, <%= address.state %> <%= address.zip_code %></p>
                <p class="text-sm text-slate-600"><%= address.country %></p>
              </div>
              <%= link_to "Edit", edit_address_path(address), class: "shrink-0 rounded-xl px-3 py-1.5 text-sm font-semibold text-slate-700 hover:bg-slate-100" %>
            </div>
          </article>
        <% end %>
      </div>
    <% end %>
  </section>

  <section class="rounded-2xl bg-white p-6 shadow-sm ring-1 ring-slate-200 sm:p-8">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
      <div>
        <h2 class="text-lg font-semibold text-slate-950">Two-factor authentication</h2>
        <p class="mt-1 text-sm text-slate-600">
          Status:
          <span class="font-semibold text-slate-900"><%= current_user.otp_required_for_login? ? "Enabled" : "Disabled" %></span>
        </p>
      </div>

      <% if current_user.otp_required_for_login? %>
        <%= link_to "Manage / Reset", two_factor_setup_page_path, class: "inline-flex items-center justify-center rounded-xl border border-slate-200 bg-white px-4 py-2.5 text-sm font-semibold text-slate-900 shadow-sm hover:bg-slate-50" %>
      <% else %>
        <%= link_to "Enable 2FA", two_factor_setup_page_path, class: "inline-flex items-center justify-center rounded-xl bg-slate-900 px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-slate-800" %>
      <% end %>
    </div>
  </section>
</div>
