<div class="mx-auto w-full max-w-md">
  <div class="rounded-2xl bg-white p-6 shadow-sm ring-1 ring-slate-200 sm:p-8">
    <div class="flex items-start justify-between gap-4">
      <div>
        <h1 class="text-xl font-semibold text-slate-900">Recover access</h1>
        <p class="mt-1 text-sm text-slate-600">Send a recovery code to <span class="break-all font-medium text-slate-900"><%= @user.email %></span> and verify it to continue.</p>
      </div>
      <span class="inline-flex items-center rounded-full bg-rose-50 px-2.5 py-1 text-xs font-semibold text-rose-700">Recovery</span>
    </div>

    <div class="mt-6">
      <%= button_to "Email me a recovery code", user_two_factor_recovery_path, method: :post, class: "inline-flex w-full items-center justify-center rounded-xl border border-slate-200 bg-white px-4 py-2.5 text-sm font-semibold text-slate-900 shadow-sm hover:bg-slate-50", data: { disable_with: "Sending..." } %>
      <p class="mt-2 text-xs text-slate-500">Codes expire after 5 minutes. Rate limits apply.</p>
    </div>

    <%= form_with url: verify_user_two_factor_recovery_path, method: :post, local: true, class: "mt-6 space-y-4", id: "recovery-otp-form" do |form| %>
      <div>
        <label class="block text-sm font-medium text-slate-700" for="recovery_otp_attempt">Recovery code</label>
        <%= hidden_field_tag :otp_attempt, "", id: "recovery_otp_attempt" %>
        <div class="mt-2 grid grid-cols-6 gap-1.5 sm:gap-3" data-otp-group>
          <% 6.times do |index| %>
            <input class="h-11 w-full rounded-xl border border-slate-300 bg-white text-center text-base font-semibold text-slate-900 shadow-sm outline-none ring-offset-2 focus:border-slate-900 focus:ring-2 focus:ring-slate-900/20 sm:h-12 sm:text-lg" inputmode="numeric" pattern="[0-9]*" maxlength="1" autocomplete="<%= index.zero? ? "one-time-code" : "off" %>" data-otp-slot aria-label="Digit <%= index + 1 %>">
          <% end %>
        </div>
      </div>

      <%= form.submit "Verify recovery code", class: "inline-flex w-full items-center justify-center rounded-xl bg-slate-900 px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-slate-800 disabled:cursor-not-allowed disabled:opacity-70", data: { disable_with: "Verifying..." } %>
      <%= link_to "Back to sign in", login_path, class: "inline-flex w-full items-center justify-center rounded-xl border border-slate-200 bg-white px-4 py-2.5 text-sm font-semibold text-slate-900 shadow-sm hover:bg-slate-50" %>
    <% end %>
  </div>
</div>

<%= render "shared/otp_input_script", form_id: "recovery-otp-form", hidden_input_id: "recovery_otp_attempt" %>
