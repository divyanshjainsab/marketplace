<div class="mx-auto w-full max-w-md">
  <div class="rounded-2xl bg-white p-6 shadow-sm ring-1 ring-slate-200 sm:p-8">
    <div class="flex items-start justify-between gap-4">
      <div>
        <h1 class="text-xl font-semibold text-slate-900">Two-factor authentication</h1>
        <p class="mt-1 text-sm text-slate-600">Protect sign-ins with a second step.</p>
      </div>
      <span class="inline-flex items-center rounded-full bg-slate-100 px-2.5 py-1 text-xs font-semibold text-slate-700">2FA</span>
    </div>

    <% if current_user.otp_required_for_login? %>
      <div class="mt-6 rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-700">
        <span class="font-semibold text-slate-900">Enabled.</span> You can reset it by disabling and enabling again.
      </div>

      <div class="mt-6 space-y-2">
        <%= button_to "Disable 2FA", users_two_factor_setup_path, method: :delete, class: "inline-flex w-full items-center justify-center rounded-xl border border-slate-200 bg-white px-4 py-2.5 text-sm font-semibold text-slate-900 shadow-sm hover:bg-slate-50", data: { disable_with: "Disabling..." } %>
        <%= link_to "Back to dashboard", root_path, class: "inline-flex w-full items-center justify-center rounded-xl bg-slate-900 px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-slate-800" %>
      </div>
    <% else %>
      <div class="mt-6 flex justify-center">
        <div class="rounded-2xl bg-white p-3 ring-1 ring-slate-200">
          <div class="w-56 sm:w-64">
            <%= @totp_setup.qr_svg %>
          </div>
        </div>
      </div>

      <div class="mt-5 rounded-xl border border-slate-200 bg-slate-50 px-4 py-3">
        <div class="text-xs font-semibold uppercase tracking-wide text-slate-500">Manual key</div>
        <div class="mt-1 break-all font-mono text-sm font-semibold text-slate-900"><%= @totp_setup.manual_key %></div>
      </div>

      <p class="mt-4 text-sm text-slate-600">Scan the QR code in your authenticator app, then enter the 6-digit code.</p>

      <%= form_with url: verify_two_factor_setup_path, method: :post, local: true, class: "mt-6 space-y-4", id: "totp-setup-form" do |form| %>
        <div>
          <label class="block text-sm font-medium text-slate-700" for="totp_setup_attempt">Authenticator code</label>
          <%= hidden_field_tag :otp_attempt, "", id: "totp_setup_attempt" %>
          <div class="mx-auto mt-2 grid max-w-xs grid-cols-6 gap-2" data-otp-group>
            <% 6.times do |index| %>
              <input class="h-11 w-full rounded-xl border border-slate-300 bg-white text-center text-base font-semibold text-slate-900 shadow-sm outline-none ring-offset-2 focus:border-slate-900 focus:ring-2 focus:ring-slate-900/20" inputmode="numeric" pattern="[0-9]*" maxlength="1" autocomplete="<%= index.zero? ? "one-time-code" : "off" %>" data-otp-slot aria-label="Digit <%= index + 1 %>">
            <% end %>
          </div>
        </div>

        <%= form.submit "Verify and enable", class: "inline-flex w-full items-center justify-center rounded-xl bg-slate-900 px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-slate-800 disabled:cursor-not-allowed disabled:opacity-70", data: { disable_with: "Verifying..." } %>

        <%= link_to "Back to dashboard", root_path, class: "inline-flex w-full items-center justify-center rounded-xl border border-slate-200 bg-white px-4 py-2.5 text-sm font-semibold text-slate-900 shadow-sm hover:bg-slate-50" %>
      <% end %>

      <%= render "shared/otp_input_script", form_id: "totp-setup-form", hidden_input_id: "totp_setup_attempt" %>
    <% end %>
  </div>
</div>
