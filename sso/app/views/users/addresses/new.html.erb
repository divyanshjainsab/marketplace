<div class="mx-auto w-full max-w-3xl">
  <div class="rounded-2xl bg-white p-6 shadow-sm ring-1 ring-slate-200 sm:p-8">
    <div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.25em] text-slate-500">Profile</p>
        <h1 class="mt-3 text-2xl font-semibold tracking-tight text-slate-950">Add address</h1>
        <p class="mt-2 text-sm text-slate-600">Use a type to distinguish home vs work.</p>
      </div>
    </div>

    <%= render "users/addresses/form", address: @address, url: addresses_path, method: :post, submit_label: "Save address" %>
  </div>
</div>

