<div class="mx-auto w-full max-w-3xl space-y-6">
  <header class="rounded-2xl bg-white p-6 shadow-sm ring-1 ring-slate-200 sm:p-8">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.25em] text-slate-500">Profile</p>
        <h1 class="mt-3 text-2xl font-semibold tracking-tight text-slate-950">Addresses</h1>
        <p class="mt-2 text-sm text-slate-600">Manage saved addresses for use across apps.</p>
      </div>

      <div class="flex items-center gap-2">
        <%= link_to "Back", profile_path, class: "inline-flex items-center justify-center rounded-xl border border-slate-200 bg-white px-4 py-2.5 text-sm font-semibold text-slate-900 shadow-sm hover:bg-slate-50" %>
        <%= link_to "Add address", new_address_path, class: "inline-flex items-center justify-center rounded-xl bg-slate-900 px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-slate-800" %>
      </div>
    </div>
  </header>

  <% if @addresses.empty? %>
    <div class="rounded-2xl border border-dashed border-slate-200 bg-white p-8 text-center shadow-sm">
      <p class="text-sm text-slate-600">No addresses saved yet.</p>
      <div class="mt-4">
        <%= link_to "Add your first address", new_address_path, class: "inline-flex items-center justify-center rounded-xl bg-slate-900 px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-slate-800" %>
      </div>
    </div>
  <% else %>
    <div class="grid gap-3 sm:grid-cols-2">
      <% @addresses.each do |address| %>
        <article class="rounded-2xl bg-white p-5 shadow-sm ring-1 ring-slate-200">
          <div class="flex items-start justify-between gap-3">
            <div class="min-w-0">
              <p class="text-xs font-semibold uppercase tracking-[0.25em] text-slate-500"><%= address.address_type %></p>
              <p class="mt-2 break-words text-sm font-semibold text-slate-900"><%= address.line1 %></p>
              <% if address.line2.present? %>
                <p class="break-words text-sm text-slate-700"><%= address.line2 %></p>
              <% end %>
              <p class="mt-2 text-sm text-slate-600"><%= address.city %>, <%= address.state %> <%= address.zip_code %></p>
              <p class="text-sm text-slate-600"><%= address.country %></p>
            </div>
            <div class="shrink-0 flex flex-col items-end gap-2">
              <%= link_to "Edit", edit_address_path(address), class: "rounded-xl px-3 py-1.5 text-sm font-semibold text-slate-700 hover:bg-slate-100" %>
              <%= button_to "Delete", address_path(address), method: :delete, class: "rounded-xl px-3 py-1.5 text-sm font-semibold text-rose-700 hover:bg-rose-50", data: { turbo_confirm: "Remove this address?" } %>
            </div>
          </div>
        </article>
      <% end %>
    </div>
  <% end %>
</div>
