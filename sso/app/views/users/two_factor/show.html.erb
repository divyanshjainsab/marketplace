<div class="mx-auto w-full max-w-md">
  <div class="rounded-2xl bg-white p-6 shadow-sm ring-1 ring-slate-200 sm:p-8">
    <div class="flex items-start justify-between gap-4">
      <div>
        <h1 class="text-xl font-semibold text-slate-900">Two-factor code</h1>
        <p class="mt-1 text-sm text-slate-600">Enter the 6-digit code from your authenticator app for <span class="font-medium text-slate-900"><%= resource.email %></span>.</p>
      </div>
      <span class="inline-flex items-center rounded-full bg-slate-100 px-2.5 py-1 text-xs font-semibold text-slate-700">2FA</span>
    </div>

    <%= form_with url: user_otp_verify_path, method: :post, local: true, class: "mt-6 space-y-4", id: "otp-form" do |form| %>
      <div>
        <label class="block text-sm font-medium text-slate-700" for="otp_attempt">Authenticator code</label>
        <%= hidden_field_tag :otp_attempt, "", id: "otp_attempt" %>
        <div class="mt-2 grid grid-cols-6 gap-2 sm:gap-3" data-otp-group>
          <% 6.times do |index| %>
            <input class="h-12 w-full rounded-xl border border-slate-300 bg-white text-center text-lg font-semibold text-slate-900 shadow-sm outline-none ring-offset-2 focus:border-slate-900 focus:ring-2 focus:ring-slate-900/20" inputmode="numeric" pattern="[0-9]*" maxlength="1" autocomplete="<%= index.zero? ? "one-time-code" : "off" %>" data-otp-slot aria-label="Digit <%= index + 1 %>">
          <% end %>
        </div>
        <div class="mt-3 flex items-center justify-between gap-3 text-xs text-slate-500">
          <span>Session expires in <strong class="text-slate-700" data-otp-countdown data-expires-at="<%= @challenge.expires_at.to_i %>"></strong></span>
          <span>Paste supported</span>
        </div>
      </div>

      <%= form.submit "Verify and continue", class: "inline-flex w-full items-center justify-center rounded-xl bg-slate-900 px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-slate-800 disabled:cursor-not-allowed disabled:opacity-70", data: { disable_with: "Verifying..." } %>

      <div class="grid grid-cols-1 gap-2 sm:grid-cols-2">
        <%= link_to "Lost access?", user_two_factor_recovery_path, class: "inline-flex w-full items-center justify-center rounded-xl border border-slate-200 bg-white px-4 py-2.5 text-sm font-semibold text-slate-900 shadow-sm hover:bg-slate-50" %>
        <%= link_to "Start over", login_path, class: "inline-flex w-full items-center justify-center rounded-xl border border-slate-200 bg-white px-4 py-2.5 text-sm font-semibold text-slate-900 shadow-sm hover:bg-slate-50" %>
      </div>
    <% end %>
  </div>
</div>

<%= render "shared/otp_input_script", form_id: "otp-form", hidden_input_id: "otp_attempt" %>
