<div class="mx-auto w-full max-w-2xl">
  <div class="rounded-2xl bg-white p-6 shadow-sm ring-1 ring-slate-200 sm:p-8">
    <div class="flex items-start justify-between gap-4">
      <div class="min-w-0">
        <h1 class="text-xl font-semibold text-slate-900">Dashboard</h1>
        <p class="mt-1 text-sm text-slate-600">Account and security settings.</p>
      </div>
      <span class="shrink-0 inline-flex items-center rounded-full bg-slate-100 px-2.5 py-1 text-xs font-semibold text-slate-700"><%= current_user.email_verified? ? "Email verified" : "Email unverified" %></span>
    </div>

    <dl class="mt-6 space-y-3 text-sm">
      <div class="flex items-center justify-between gap-3 rounded-xl bg-slate-50 px-4 py-3">
        <dt class="text-slate-600">Name</dt>
        <dd class="truncate font-semibold text-slate-900"><%= current_user.name.presence || "—" %></dd>
      </div>
      <div class="flex items-center justify-between gap-3 rounded-xl bg-slate-50 px-4 py-3">
        <dt class="text-slate-600">Email</dt>
        <dd class="truncate font-semibold text-slate-900"><%= current_user.email %></dd>
      </div>
    </dl>

    <div class="mt-8 border-t border-slate-200 pt-6">
      <div class="flex items-center justify-between gap-4">
        <div>
          <div class="text-sm font-semibold text-slate-900">Two-Factor Authentication</div>
          <div class="mt-1 text-sm text-slate-600">
            Status:
            <span class="font-semibold text-slate-900"><%= current_user.otp_required_for_login? ? "Enabled" : "Disabled" %></span>
          </div>
        </div>

        <% if current_user.otp_required_for_login? %>
          <%= link_to "Manage / Reset", two_factor_setup_page_path, class: "inline-flex items-center justify-center rounded-xl border border-slate-200 bg-white px-4 py-2.5 text-sm font-semibold text-slate-900 shadow-sm hover:bg-slate-50" %>
        <% else %>
          <%= link_to "Enable 2FA", two_factor_setup_page_path, class: "inline-flex items-center justify-center rounded-xl bg-slate-900 px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-slate-800" %>
        <% end %>
      </div>
    </div>
  </div>
</div>
